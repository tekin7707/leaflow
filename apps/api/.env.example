# Lokal dev (Yol B). Docker host'a 7050 portunda map ediyor postgres'i.
DATABASE_URL="postgresql://provit:provit@localhost:7050/provit"
JWT_SECRET="dev-secret-change-me"
PORT=4000
WEB_ORIGIN="http://localhost:5173"
LOG_LEVEL=info
UPLOAD_DIR=./uploads
PUBLIC_API_URL="http://localhost:4000"

# Agentechauth (dış login + takım servisi).
# AUTH_MODE=mock     → DB'deki seed kullanıcılarıyla giriş (default if API_KEY empty)
# AUTH_MODE=agentech → Gerçek Agentechauth servisine bağlanır
AUTH_MODE=mock
AGENTECHAUTH_BASE_URL="https://api.agentechauth.com/api"
AGENTECHAUTH_API_KEY=""
